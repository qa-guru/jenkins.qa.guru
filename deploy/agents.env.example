# Copy to /var/docker-compose-config/agents.env on the server — never commit real values.
# One-time: copy secrets from the existing docker-compose.yml command lines
# (Jenkins → Manage Jenkins → Nodes → agent → secret is in compose today).

JENKINS_IMAGE=jenkins/jenkins:jdk21

JDK21_AGENT_1_SECRET=replace-me
JDK21_AGENT_2_SECRET=replace-me
JDK21_AGENT_3_SECRET=replace-me

PYTHON3_AGENT_1_SECRET=replace-me
PYTHON3_AGENT_2_SECRET=replace-me
PYTHON3_AGENT_3_SECRET=replace-me
