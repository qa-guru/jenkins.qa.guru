# Copy to /var/docker-compose-config/agents.env on the server — never commit real values.
# One-time: copy secrets from Jenkins → Manage Jenkins → Nodes → agent → secret.

JENKINS_IMAGE=jenkins/jenkins:jdk21

JAVA_JDK21_AGENT_1_SECRET=replace-me
JAVA_JDK21_AGENT_2_SECRET=replace-me
JAVA_JDK21_AGENT_3_SECRET=replace-me
JAVA_JDK21_AGENT_4_SECRET=replace-me
JAVA_JDK21_AGENT_5_SECRET=replace-me

PYTHON_PYTHON314_AGENT_1_SECRET=replace-me
PYTHON_PYTHON314_AGENT_2_SECRET=replace-me
PYTHON_PYTHON314_AGENT_3_SECRET=replace-me
PYTHON_PYTHON314_AGENT_4_SECRET=replace-me
PYTHON_PYTHON314_AGENT_5_SECRET=replace-me
